# =============================
# Hilo Service - Environnement
# =============================

# Serveur (Clever : nginx 8080 -> 9000)
PORT=9000
LOG_LEVEL=info

# Supabase (projet soriya-dev, schema hilo expose dans l API)
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Chatwoot
CHATWOOT_URL=https://chatwoot-hilo.cleverapps.io
CHATWOOT_API_TOKEN=xxxxxxxxxxxxxx
CHATWOOT_ACCOUNT_ID=1

# Anthropic (V1 - generations LLM ; inutile en V0)
ANTHROPIC_API_KEY=

# Canonical local (fallback)
CANONICAL_PATH=configs/canonical_snapshot.json
